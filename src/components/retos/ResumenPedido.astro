---
import "../../styles/retos/styles-resumen-pedido.css";
import { Image } from "astro:assets";
import HeaderImg from "../../assets/images/resumen-pedido/illustration-hero.svg";
import NoteSvg from "../../assets/images/resumen-pedido/icon-music.svg";
---

<div class="resumen-pedido">
  <div class="resumen-card overflow-hidden">
    <div class="header-card">
      <Image src={HeaderImg} alt="Resumen del pedido" class="header-img" />
    </div>
    <div class="resumen-content">
      <h3 class="resumen-title">Order Summary</h3>
      <p class="resumen-description">
        You can now listen to millions of songs, audiobooks, and podcasts on any
        device anywhere you like!
      </p>
      <div class="plan-info">
        <div class="plan-details">
          <Image src={NoteSvg} alt="Music Icon" class="plan-icon" />
          <div>
            <h3>Annual Plan</h3>
            <p>$59.99/year</p>
          </div>
        </div>
        <a href="">Change</a>
      </div>
    </div>

    <!-- Contenido del componente -->
    <div class="actions-buttons">
      <button class="proceed-btn"> Proceed to Payment </button>
      <button class="cancel-btn"> Cancel Order </button>
    </div>
  </div>
</div>
